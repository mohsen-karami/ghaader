{
	"editor.tabSize": 4,
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"editor.trimTrailingWhitespace": true,
	"editor.formatOnSave": false,
	"eslint.enable": true,
	"eslint.useFlatConfig": true,
	"eslint.validate": [
		"javascript"
	],
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "never"
	}
}
